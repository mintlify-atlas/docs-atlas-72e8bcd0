  "keyFeatures": [
    "Multi-role authentication via Firebase Auth (Google SSO, @umss.edu domain restricted)",
    "Product catalog with categories, search, offers, and reviews",
    "Cart, checkout, and order tracking for buyers",
    "Seller portal for order reception, packaging, and dispatch management",
    "Courier mobile-friendly delivery flow with session management and cash reconciliation",
    "Inventory management with stock entries, exits, movements, and alerts",
    "Admin dashboard with analytics, audit logs, user management, and payment reconciliation",
    "PWA support (installable, offline-ready) with Vercel deployment",
    "Firestore-backed real-time data with local emulator support for development",
    "E2E tests with Playwright and unit tests with Vitest"
  ],
  "publicApiSurface": [
    "GET /api/admin/order_history",
    "GET /api/admin/orders_list",
    "GET /api/admin/courier_sessions",
    "GET /api/admin/top_products",
    "GET /api/seller/pending-orders",
    "GET /api/seller/daily-collections",
    "GET /api/users",
    "Firebase Auth (Google OAuth, @umss.edu domain restriction)",
    "Firestore collections: users, products, categories, orders, orderItems, deliveries, payments, inventory, inventoryMovements, reviews, cartItems, favorites, notifications, courierSessions, accessLogs, sellerActivityLogs, settings"
  ]
